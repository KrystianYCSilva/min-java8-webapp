<?xml version="1.0" encoding="UTF-8"?>
<zk>
    <system-config>
        <disable-event-thread>true</disable-event-thread>
    </system-config>

    <session-config>
        <session-timeout>30</session-timeout>
        <max-desktops-per-session>15</max-desktops-per-session>
    </session-config>

    <library-property>
        <name>org.zkoss.zk.ui.disable-zscript</name>
        <value>true</value>
    </library-property>

    <library-property>
        <name>org.zkoss.zk.ui.checkClassWebResource</name>
        <value>false</value>
    </library-property>

    <!-- ZK 8 Theme Configuration: IceBlue Compact (Bootstrap-style) -->
    <library-property>
        <name>org.zkoss.theme.preferred</name>
        <value>iceblue_c</value>
    </library-property>

    <!-- Enable responsive design -->
    <library-property>
        <name>org.zkoss.zul.grid.autofitWidth</name>
        <value>true</value>
    </library-property>

    <!-- Enable modern look & feel -->
    <library-property>
        <name>org.zkoss.zul.listbox.checkmarkDeselectOthers</name>
        <value>false</value>
    </library-property>
</zk>
